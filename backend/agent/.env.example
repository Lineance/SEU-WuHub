# Agent LLM配置示例

# 支持的模型格式见 https://github.com/BerriAI/litellm#supported-models
# OpenAI官方API
LITELLM_API_KEY=sk-xxx
SEU_WUHUB_AGENT_MODEL=openai/gpt-4o-mini

# Azure OpenAI
# LITELLM_API_TYPE=azure
# LITELLM_API_BASE=https://xxx.openai.azure.com/
# LITELLM_API_KEY=azure-key
# SEU_WUHUB_AGENT_MODEL=azure/gpt-35-turbo

# 其他模型（如 moonshot、baichuan、qwen、glm 等）
# 参考 litellm 文档配置

# 运行参数可在 agent/config.py 调整
# 如 temperature、max_tokens、timeout 等
